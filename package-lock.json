"""
Caption editing endpoints: edit text, merge, split, search & replace.
"""
from fastapi import APIRouter, Depends, HTTPException
from pydantic import BaseModel
from app.core.security import get_current_user
from app.models.database import SessionLocal
from app.models.project import CaptionSegment

router = APIRouter()


class SegmentUpdate(BaseModel):
    tanglish_text: str


class MergeRequest(BaseModel):
    segment_ids: list[str]


class SplitRequest(BaseModel):
    segment_id: str
    split_at_char: int


class SearchReplaceRequest(BaseModel):
    project_id: str
    search: str
    replace: str


@router.patch("/segment/{segment_id}")
def update_segment(segment_id: str, payload: SegmentUpdate, user=Depends(get_current_user)):
    db = SessionLocal()
    try:
        seg = db.query(CaptionSegment).filter(CaptionSegment.id == segment_id).first()
        if not seg:
            raise HTTPException(404, "Segment not found")
        seg.tanglish_text = payload.tanglish_text
        seg.edited = True
        db.commit()
        return {"id": seg.id, "tanglish_text": seg.tanglish_text}
    finally:
        db.close()


@router.post("/merge")
def merge_segments(payload: MergeRequest, user=Depends(get_current_user)):
    db = SessionLocal()
    try:
        segs = (
            db.query(CaptionSegment)
            .filter(CaptionSegment.id.in_(payload.segment_ids))
            .order_by(CaptionSegment.start_time)
            .all()
        )
        if len(segs) < 2:
            raise HTTPException(400, "Need at least 2 segments to merge")

        merged_text = " ".join(s.tanglish_text for s in segs)
        first, rest = segs[0], segs[1:]
        first.tanglish_text = merged_text
        first.end_time = segs[-1].end_time
        first.edited = True

        for s in rest:
            db.delete(s)

        db.commit()
        return {"id": first.id, "tanglish_text": first.tanglish_text,
                "start": first.start_time, "end": first.end_time}
    finally:
        db.close()


@router.post("/split")
def split_segment(payload: SplitRequest, user=Depends(get_current_user)):
    db = SessionLocal()
    try:
        seg = db.query(CaptionSegment).filter(CaptionSegment.id == payload.segment_id).first()
        if not seg:
            raise HTTPException(404, "Segment not found")

        text = seg.tanglish_text
        part1, part2 = text[:payload.split_at_char].strip(), text[payload.split_at_char:].strip()
        if not part1 or not part2:
            raise HTTPException(400, "Invalid split point")

        mid_time = seg.start_time + (seg.end_time - seg.start_time) * (len(part1) / len(text))

        seg.tanglish_text = part1
        seg.end_time = mid_time
        seg.edited = True

        new_seg = CaptionSegment(
            project_id=seg.project_id,
            start_time=mid_time,
            end_time=seg.end_time if seg.end_time > mid_time else mid_time + 0.5,
            tanglish_text=part2,
            edited=True,
            order_index=seg.order_index + 1,
        )
        db.add(new_seg)
        db.commit()
        return {"first": {"id": seg.id, "text": part1}, "second": {"id": new_seg.id, "text": part2}}
    finally:
        db.close()


@router.post("/search-replace")
def search_replace(payload: SearchReplaceRequest, user=Depends(get_current_user)):
    db = SessionLocal()
    try:
        segs = db.query(CaptionSegment).filter(CaptionSegment.project_id == payload.project_id).all()
        count = 0
        for s in segs:
            if payload.search.lower() in s.tanglish_text.lower():
                s.tanglish_text = s.tanglish_text.replace(payload.search, payload.replace)
                s.edited = True
                count += 1
        db.commit()
        return {"replaced_in_segments": count}
    finally:
        db.close()
