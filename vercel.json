"""
Auth verification passthrough — actual session creation happens in
Clerk/NextAuth on the frontend. This endpoint just confirms identity
and syncs the user record to our DB on first login.
"""
from fastapi import APIRouter, Depends
from app.core.security import get_current_user

router = APIRouter()


@router.get("/me")
def get_me(user=Depends(get_current_user)):
    return user
